# Django core settings
SECRET_KEY=your-production-secret-key-here
DEBUG=False
HOST=https://your-production-host.com
ALLOWED_HOSTS=your-production-host.com
PAGE_SIZE=12
TEST_HEADLESS=False

# CORS / CSRF settings (optional)
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
CSRF_TRUSTED_ORIGINS=https://your-frontend-domain.com

# Storage
STORAGE_AWS=True
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_STORAGE_BUCKET_NAME=your-aws-bucket-name

# Database
DB_ENGINE=django.db.backends.postgresql_psycopg2
DB_NAME=production-db-name
DB_USER=production-db-user
DB_PASSWORD=production-db-password
DB_HOST=your-db-host
DB_PORT=5432

# Reports
BAR_CHART_ENDPOINT=https://your-production-graph-generator-url.com

# testing
TEST_BAR_CHART_ENDPOINT=https://your-production-graph-generator-url.com/

# Integrations
N8N_BASE_WEBHOOKS=https://your-n8n-url.com/webhook

#Titles
PDF_REPORT_TITLE="Alfabetización Tecnológica"
PDF_REPORT_ACRONYM="AFT"
